# CodeSmith AI -- backend environment variables
# Copy this file to .env in the same folder (backend/.env) and fill in
# whichever keys you have. You need at least ONE LLM provider key for
# generation to work at all -- but the more you fill in, the more
# resilient the fallback chain is when any single provider hits a rate
# limit or quota.

# ── LLM Providers (fallback chain: Groq -> Gemini -> Cerebras -> Mistral -> OpenRouter -> NVIDIA) ──

# Groq -- fast, free, daily-reset quota. Get a key: https://console.groq.com
GROQ_API_KEY=

# Google Gemini -- free, daily-reset quota (~1,500 req/day on Flash).
# Get a key: https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Mistral -- free, monthly-reset quota. Get a key: https://console.mistral.ai
MISTRAL_API_KEY=

# OpenRouter -- free shared model pool, single key across 20+ models.
# Get a key: https://openrouter.ai/keys
OPENROUTER_API_KEY=

# Cerebras -- free, ~1M tokens/day, daily reset. Get a key: https://cloud.cerebras.ai
CEREBRAS_API_KEY=
# Optional: override the model if the hardcoded default in
# app/llms/cerebras.py ever gets deprecated/404s. Find current model IDs
# via: curl https://api.cerebras.ai/v1/models -H "Authorization: Bearer $CEREBRAS_API_KEY"
CEREBRAS_MODEL=

# NVIDIA NIM -- free, but a ONE-TIME credit pool (not daily-refilling),
# so it's used as the last-resort fallback. Get a key: https://build.nvidia.com
NVIDIA_API_KEY=
# Optional: override the model if the hardcoded default in
# app/llms/nvidia.py ever gets deprecated. Browse current models at
# https://build.nvidia.com/models
NVIDIA_MODEL=

# ── CORS ──

# Comma-separated list of frontend URLs allowed to call this backend.
# Add your Vercel/Netlify URL here when deploying.
# Example: https://codesmith-ai.vercel.app,https://my-custom-domain.com
ALLOWED_ORIGINS=
